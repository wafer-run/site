# wafer-site env config.
#
# Copy to `.env` (gitignored) and fill in your values.
# Native runs read these directly; the cloudflare deploy flow reads
# CLOUDFLARE_* and SOLOBASE_CLOUDFLARE_* from this file too.

# ──────────────────────────────────────────────────────────────────────
# Native run (solobase serve)
# ──────────────────────────────────────────────────────────────────────

SOLOBASE_DB_PATH=./data/manual/db.sqlite
SOLOBASE_STORAGE_ROOT=./data/manual/storage
SOLOBASE_LISTEN=0.0.0.0:8090

# JWT signing key. On native this comes from env; on cloudflare it must
# be set via `wrangler secret put SUPPERS_AI__AUTH__JWT_SECRET`.
SUPPERS_AI__AUTH__JWT_SECRET=change-me-to-a-random-string

SOLOBASE_SHARED__APP_NAME=wafer.run
SOLOBASE_SHARED__FRONTEND_URL=http://localhost:8090
SOLOBASE_SHARED__ALLOW_SIGNUP=false
SOLOBASE_SHARED__ENABLE_OAUTH=true

# Admin / registry
SOLOBASE_SHARED__AUTH__BOOTSTRAP_ADMIN_EMAIL=you@example.com
SUPPERS_AI__AUTH__REQUIRE_VERIFICATION=true
WAFER_RUN__REGISTRY__ADMIN_EMAIL=you@example.com
WAFER_RUN__REGISTRY__REQUIRED_AUTH_METHOD=oauth.github

# GitHub OAuth (https://github.com/settings/developers). The redirect URI
# is provider-agnostic — the provider is encoded in the signed `state` JWT
# by the single-callback flow at `/b/auth/oauth/callback`.
SUPPERS_AI__AUTH_UI__OAUTH_GITHUB_CLIENT_ID=
SUPPERS_AI__AUTH_UI__OAUTH_GITHUB_CLIENT_SECRET=
SUPPERS_AI__AUTH_UI__OAUTH_REDIRECT_URI=http://localhost:8090/b/auth/oauth/callback

# Stubs — site doesn't use these blocks but solobase-core forces config presence.
SUPPERS_AI__LEGALPAGES__FOOTER=footer
SUPPERS_AI__LLM__DEFAULT_MODEL=gpt-4o-mini

# ──────────────────────────────────────────────────────────────────────
# Cloudflare deploy (solobase deploy --target cloudflare)
# ──────────────────────────────────────────────────────────────────────
#
# Required:
#   1. CLOUDFLARE_ACCOUNT_ID      — your CF account id (`wrangler whoami`)
#   2. CLOUDFLARE_API_TOKEN       — token with R2 + D1 + Workers permissions
#   3. SOLOBASE_CLOUDFLARE_D1_DATABASE_ID — id from `wrangler d1 create <name>`
#   4. SOLOBASE_DEPLOY_TOKEN      — any random string; also pushed as a
#                                   worker secret via `secret` (see below)
#
# Optional (override toml defaults from solobase.toml):
#   SOLOBASE_CLOUDFLARE_WORKER_NAME=wafer-site
#   SOLOBASE_CLOUDFLARE_COMPATIBILITY_DATE=2026-05-01
#   SOLOBASE_CLOUDFLARE_D1_DATABASE_NAME=wafer-site-prod
#   SOLOBASE_CLOUDFLARE_R2_BUCKET_NAME=wafer-site-assets

CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
SOLOBASE_CLOUDFLARE_D1_DATABASE_ID=

# Deploy-init auth token: `solobase deploy` sends this as the
# `x-deploy-token` header to the freshly-uploaded version's `/_deploy/init`,
# which runs migrations + seeds and gates promotion on success. Required by
# both `./scripts/deploy-cloudflare.sh secret` (which also pushes it as the
# worker secret of the same name) and `./scripts/deploy-cloudflare.sh deploy`
# (which reads it from env to send the header) — any random string, same
# value both places.
SOLOBASE_DEPLOY_TOKEN=

# Worker secrets — set these via `./scripts/deploy-cloudflare.sh secret`
# (or `wrangler secret put` directly) AFTER first build, not via this file.
# Wrangler reads worker secrets from CF, not env.
#
#   solobase build --target cloudflare
#   wrangler secret put SUPPERS_AI__AUTH__JWT_SECRET \
#     --config target/solobase-cloudflare/wrangler.toml
#   wrangler secret put SOLOBASE_DEPLOY_TOKEN \
#     --config target/solobase-cloudflare/wrangler.toml
