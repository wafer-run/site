# wafer-site env config.
#
# Copy to `.env` (gitignored) and fill in your values.
# Native runs read these directly; the cloudflare deploy flow reads
# CLOUDFLARE_* and IMPRESSPRESS_CLOUDFLARE_* from this file too.

# ──────────────────────────────────────────────────────────────────────
# Native run (impresspress serve)
# ──────────────────────────────────────────────────────────────────────

IMPRESSPRESS_DB_PATH=./data/manual/db.sqlite
IMPRESSPRESS_STORAGE_ROOT=./data/manual/storage
IMPRESSPRESS_LISTEN=0.0.0.0:8090

# JWT signing key. On native this comes from env; on cloudflare it must
# be set via `wrangler secret put WAFER_RUN__AUTH__JWT_SECRET`.
WAFER_RUN__AUTH__JWT_SECRET=change-me-to-a-random-string

WAFER_RUN_SHARED__APP_NAME=wafer.run
WAFER_RUN_SHARED__FRONTEND_URL=http://localhost:8090
WAFER_RUN_SHARED__ALLOW_SIGNUP=false
WAFER_RUN_SHARED__ENABLE_OAUTH=true

# Admin / registry
WAFER_RUN_SHARED__AUTH__BOOTSTRAP_ADMIN_EMAIL=you@example.com
WAFER_RUN__AUTH__REQUIRE_VERIFICATION=true
WAFER_RUN__REGISTRY__ADMIN_EMAIL=you@example.com
WAFER_RUN__REGISTRY__REQUIRED_AUTH_METHOD=oauth.github

# GitHub OAuth (https://github.com/settings/developers). The redirect URI
# is provider-agnostic — the provider is encoded in the signed `state` JWT
# by the single-callback flow at `/b/auth/oauth/callback`.
IMPRESSPRESS__AUTH_UI__OAUTH_GITHUB_CLIENT_ID=
IMPRESSPRESS__AUTH_UI__OAUTH_GITHUB_CLIENT_SECRET=
IMPRESSPRESS__AUTH_UI__OAUTH_REDIRECT_URI=http://localhost:8090/b/auth/oauth/callback

# Stubs — site doesn't use these blocks but impresspress-core forces config presence.
IMPRESSPRESS__LEGALPAGES__FOOTER=footer
IMPRESSPRESS__LLM__DEFAULT_MODEL=gpt-4o-mini

# ──────────────────────────────────────────────────────────────────────
# Cloudflare deploy (impresspress deploy --target cloudflare)
# ──────────────────────────────────────────────────────────────────────
#
# Required:
#   1. CLOUDFLARE_ACCOUNT_ID      — your CF account id (`wrangler whoami`)
#   2. CLOUDFLARE_API_TOKEN       — token with R2 + D1 + Workers permissions
#   3. IMPRESSPRESS_CLOUDFLARE_D1_DATABASE_ID — id from `wrangler d1 create <name>`
#   4. IMPRESSPRESS_DEPLOY_TOKEN      — any random string; also pushed as a
#                                   worker secret via `secret` (see below)
#
# Optional (override toml defaults from impresspress.toml):
#   IMPRESSPRESS_CLOUDFLARE_WORKER_NAME=wafer-site
#   IMPRESSPRESS_CLOUDFLARE_COMPATIBILITY_DATE=2026-05-01
#   IMPRESSPRESS_CLOUDFLARE_D1_DATABASE_NAME=wafer-site-prod
#   IMPRESSPRESS_CLOUDFLARE_R2_BUCKET_NAME=wafer-site-assets

CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
IMPRESSPRESS_CLOUDFLARE_D1_DATABASE_ID=

# Deploy-init auth token: `impresspress deploy` sends this as the
# `x-deploy-token` header to the freshly-uploaded version's `/_deploy/init`,
# which runs migrations + seeds and gates promotion on success. Required by
# both `./scripts/deploy-cloudflare.sh secret` (which also pushes it as the
# worker secret of the same name) and `./scripts/deploy-cloudflare.sh deploy`
# (which reads it from env to send the header) — any random string, same
# value both places.
IMPRESSPRESS_DEPLOY_TOKEN=

# Worker secrets — set these via `./scripts/deploy-cloudflare.sh secret`
# (or `wrangler secret put` directly) AFTER first build, not via this file.
# Wrangler reads worker secrets from CF, not env.
#
#   impresspress build --target cloudflare
#   wrangler secret put WAFER_RUN__AUTH__JWT_SECRET \
#     --config target/impresspress-cloudflare/wrangler.toml
#   wrangler secret put IMPRESSPRESS_DEPLOY_TOKEN \
#     --config target/impresspress-cloudflare/wrangler.toml
