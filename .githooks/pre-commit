#!/usr/bin/env bash
set -e

# Activate this hook per-clone with:
#   git config core.hooksPath .githooks

# ── Rust: fmt + clippy on staged .rs files ──────────────────────────
RS_FILES=$(git diff --cached --name-only --diff-filter=ACMR -- '*.rs')
if [ -n "$RS_FILES" ]; then
  echo "Running cargo fmt..."
  cargo fmt --all
  git add $RS_FILES

  echo "Running cargo clippy --fix..."
  cargo clippy --all-targets --fix --allow-dirty --allow-staged -- -D warnings 2>&1 || {
    echo "❌ clippy found warnings it couldn't auto-fix. Please fix manually and re-stage."
    exit 1
  }
  git add $RS_FILES
fi

echo "✓ Pre-commit checks passed."
